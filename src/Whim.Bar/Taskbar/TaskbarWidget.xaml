<UserControl
	x:Class="Whim.Bar.TaskbarWidget"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:local="using:Whim.Bar"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	d:DataContext="{d:DesignInstance Type=local:TaskbarWidgetViewModel}"
	d:DesignHeight="450"
	d:DesignWidth="800"
	mc:Ignorable="d"
>
	<StackPanel Orientation="Horizontal">
		<!--  Current workspace windows  -->
		<ItemsControl ItemsSource="{x:Bind ViewModel.CurrentWorkspaceWindows}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal" />
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate x:DataType="local:TaskbarWindowModel">
					<Button
						Command="{x:Bind ActivateWindowCommand}"
						MaxWidth="200"
						Style="{StaticResource bar:workspace:button}"
						ToolTipService.ToolTip="{x:Bind Title}"
					>
						<Button.Resources>
							<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource bar:hover:background}" />
							<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource bar:hover:foreground}" />
						</Button.Resources>
						<TextBlock
							Text="{x:Bind Title}"
							TextTrimming="CharacterEllipsis"
							TextWrapping="NoWrap"
						/>
					</Button>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>

		<!--  Other workspace windows (dimmed, clicking moves them here)  -->
		<ItemsControl ItemsSource="{x:Bind ViewModel.OtherWorkspaceWindows}">
			<ItemsControl.ItemsPanel>
				<ItemsPanelTemplate>
					<StackPanel Orientation="Horizontal" />
				</ItemsPanelTemplate>
			</ItemsControl.ItemsPanel>
			<ItemsControl.ItemTemplate>
				<DataTemplate x:DataType="local:TaskbarWindowModel">
					<Button
						Command="{x:Bind ActivateWindowCommand}"
						MaxWidth="200"
						Opacity="0.5"
						Style="{StaticResource bar:workspace:button}"
						ToolTipService.ToolTip="{x:Bind WorkspaceName}"
					>
						<Button.Resources>
							<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="{StaticResource bar:hover:background}" />
							<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="{StaticResource bar:hover:foreground}" />
						</Button.Resources>
						<TextBlock
							Text="{x:Bind Title}"
							TextTrimming="CharacterEllipsis"
							TextWrapping="NoWrap"
						/>
					</Button>
				</DataTemplate>
			</ItemsControl.ItemTemplate>
		</ItemsControl>
	</StackPanel>
</UserControl>
